// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pengguna {
  id          String   @id @default(uuid())
  nama        String
  username    String   @unique
  email       String   @unique
  kataSandi   String   @map("kata_sandi")
  role        Role     @default(PELANGGAN)
  waktuDibuat DateTime @default(now()) @map("waktu_dibuat")
  waktuDiubah DateTime @updatedAt @map("waktu_diubah")
  orders Order[]

  @@map("pengguna")
}

enum Role {
  ADMIN
  PELANGGAN
}

model Category {
  id            String    @id @default(uuid())
  namaKategori  String    @unique
  deskripsi     String?   @db.Text
  waktuDibuat   DateTime  @default(now())
  waktuDiupdate DateTime  @updatedAt
  products      Product[]

  @@map("categories")
}

model Product {
  id            String      @id @default(uuid())
  namaProduk    String
  deskripsi     String      @db.Text
  harga         Int
  stok          Int         @default(0)
  gambar        String?
  categoryId    String
  category      Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  waktuDibuat   DateTime    @default(now())
  waktuDiupdate DateTime    @updatedAt
  OrderItem     OrderItem[]

  @@map("products")
}

enum OrderStatus {
  PENDING
  DIPROSES
  DIKIRIM
  SELESAI
  DIBATALKAN
}

enum DesignStatus {
  MENUNGGU
  DISETUJUI
  DITOLAK
}

enum PaymentStatus {
  BELUM_BAYAR
  DP
  LUNAS
}

enum JenisSablon {
  PLASTISOL
  RUBBER
  DISCHARGE
  DTF
  DTG
}

// --- UPDATE TABEL ORDER ---
model Order {
  id     String @id @default(uuid())
  userId String
  pengguna         Pengguna      @relation(fields: [userId], references: [id])

  // Sistem Pembayaran & DP
  totalHarga       Int
  dpAmount         Int           @default(0)
  sisaPembayaran   Int           @default(0)
  statusPembayaran PaymentStatus @default(BELUM_BAYAR)
  status           OrderStatus   @default(PENDING)

  alamatPengiriman String   @db.Text
  catatanCustom    String?  @db.Text
  waktuDibuat      DateTime @default(now())
  waktuDiupdate    DateTime @updatedAt

  //verifikasi pembayaran
  buktiPembayaran  String?
  tanggalBayar     DateTime?

  items OrderItem[]

  @@map("orders")
}

// --- UPDATE TABEL ORDER ITEM ---
model OrderItem {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  jumlah      Int
  hargaSatuan Int

  // desain costum
  jenisSablon     JenisSablon?
  gambarDesain    String?
  deskripsiDesain String?      @db.Text
  statusDesain    DesignStatus @default(MENUNGGU)
  catatanAdmin    String?      @db.Text

  @@map("order_items")
}

model PengaturanToko {
  id              Int      @id @default(1)
  namaToko        String   @default("Glowear")
  whatsappCS      String?
  namaBank        String?
  nomorRekening   String?
  atasNamaBank    String?
  syaratKetentuan String?  @db.Text
  waktuDiubah     DateTime @updatedAt

  @@map("pengaturan_toko")
}

model Banner {
  id          String   @id @default(uuid())
  judul       String
  gambar      String
  link        String?
  status      Boolean  @default(true)
  waktuDibuat DateTime @default(now())

  @@map("banners")
}

model Portofolio {
  id          String   @id @default(uuid())
  judul       String
  deskripsi   String?  @db.Text
  gambar      String   // Nama file gambar
  kategori    String   // Misal: "Kaos", "Hoodie", "Polo"
  waktuDibuat DateTime @default(now()) @map("waktu_dibuat")

  @@map("portofolio")
}