// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pengguna {
  id          String   @id @default(uuid())
  nama        String
  username    String   @unique
  email       String   @unique
  kataSandi   String   @map("kata_sandi")
  role        Role     @default(PELANGGAN)
  waktuDibuat DateTime @default(now()) @map("waktu_dibuat")
  waktuDiubah DateTime @updatedAt @map("waktu_diubah")

  @@map("pengguna")
}

enum Role {
  ADMIN
  PELANGGAN
}

model Category {
  id            String    @id @default(uuid())
  namaKategori  String    @unique
  deskripsi     String?   @db.Text
  waktuDibuat   DateTime  @default(now())
  waktuDiupdate DateTime  @updatedAt
  products      Product[]

  @@map("categories")
}

model Product {
  id            String   @id @default(uuid())
  namaProduk    String
  deskripsi     String   @db.Text
  harga         Int      
  stok          Int      @default(0)
  gambar        String?  
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  waktuDibuat   DateTime @default(now())
  waktuDiupdate DateTime @updatedAt

  @@map("products")
}